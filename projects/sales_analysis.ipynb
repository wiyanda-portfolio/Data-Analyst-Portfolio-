import pandas as pd
import matplotlib.pyplot as plt

# Load dataset
df = pd.read_csv("../datasets/sales_dataset.csv", sep=";")

print("Dataset Preview")
print(df.head())

# =========================
# Total Sales per Product
# =========================

sales_product = df.groupby("product")["total_sales"].sum().sort_values(ascending=False)

print("\nTop Products by Revenue:")
print(sales_product)

sales_product.plot(kind="bar")
plt.title("Total Sales by Product")
plt.ylabel("Revenue")
plt.show()

# =========================
# Total Sales per City
# =========================

sales_city = df.groupby("city")["total_sales"].sum().sort_values(ascending=False)

print("\nTop Cities by Sales:")
print(sales_city)

sales_city.plot(kind="bar")
plt.title("Total Sales by City")
plt.ylabel("Revenue")
plt.show()

# =========================
# Most Purchased Product
# =========================

quantity_product = df.groupby("product")["quantity"].sum().sort_values(ascending=False)

print("\nMost Purchased Products:")
print(quantity_product)

quantity_product.plot(kind="bar")
plt.title("Quantity Sold by Product")
plt.ylabel("Quantity")
plt.show()
